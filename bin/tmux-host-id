#!/bin/sh
python3 - <<'EOF'
import hashlib, socket
h = hashlib.md5(socket.gethostname().encode()).hexdigest()
emojis = [
  'рҹҗ¶','рҹҗұ','рҹҗӯ','рҹҗ№','рҹҗ°','рҹҰҠ','рҹҗ»','рҹҗј','рҹҗЁ','рҹҗҜ',
  'рҹҰҒ','рҹҗ®','рҹҗ·','рҹҗё','рҹҗө','рҹҰ„','рҹҗқ','рҹҰӢ','рҹҗҢ','рҹҗһ',
  'рҹҰҺ','рҹҗҚ','рҹҰ‘','рҹҗҷ','рҹҰҖ','рҹҗЎ','рҹҗ ','рҹҗҹ','рҹҗ¬','рҹҗі',
  'рҹҰҲ','рҹҗҠ','рҹҗ…','рҹҗҶ','рҹҰҚ','рҹҗҳ','рҹҰӣ','рҹҰҸ','рҹҗӘ','рҹҰ’',
  'рҹҰҳ','рҹҗҺ','рҹҗҗ','рҹҰҢ','рҹҗ•','рҹҗҲ','рҹҰ…','рҹҰҶ','рҹҰү','рҹҰӢ',
]
emoji = emojis[int(h[5:9], 16) % len(emojis)]
print(emoji + ' ' + h[:5])
EOF
